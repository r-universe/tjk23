[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "GLSUP"]
	path = GLSUP
	url = https://github.com/cran/GLSUP
[submodule "PoissonPCA"]
	path = PoissonPCA
	url = https://github.com/cran/PoissonPCA
[submodule "SHRED"]
	path = SHRED
	url = https://github.com/cran/SHRED
[submodule "SuRF.vs"]
	path = SuRF.vs
	url = https://github.com/cran/SuRF.vs
